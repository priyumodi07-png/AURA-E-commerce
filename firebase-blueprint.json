{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An e-commerce product listed in the catalog",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier of the product" },
        "name": { "type": "string", "description": "Name of the product" },
        "description": { "type": "string", "description": "Full description of the product" },
        "price": { "type": "number", "description": "Price in USD" },
        "image": { "type": "string", "description": "URL of the product image" },
        "category": { "type": "string", "description": "Category of the product" },
        "stock": { "type": "integer", "description": "Available stock quantity" },
        "rating": { "type": "number", "description": "Average rating of the product out of 5" },
        "featured": { "type": "boolean", "description": "Whether this is a featured product" }
      },
      "required": ["name", "price", "image", "category", "stock"]
    },
    "User": {
      "title": "User Profile",
      "description": "Registered user profile details",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "fullName": { "type": "string", "description": "Full name" },
        "address": { "type": "string", "description": "Shipping address" },
        "phone": { "type": "string", "description": "Contact phone number" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["email", "fullName"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order containing item details and status",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique order ID" },
        "userId": { "type": "string", "description": "The UID of the user who placed the order, or 'guest'" },
        "customerName": { "type": "string", "description": "Name for shipping" },
        "customerEmail": { "type": "string", "format": "email", "description": "Email for contact" },
        "shippingAddress": { "type": "string", "description": "Full shipping address" },
        "items": {
          "type": "array",
          "description": "List of ordered items"
        },
        "totalAmount": { "type": "number", "description": "Total order price in USD" },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Shipped", "Delivered"], "description": "Current state of the order" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the order was placed" }
      },
      "required": ["userId", "customerName", "customerEmail", "shippingAddress", "items", "totalAmount", "status", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of e-commerce products available for purchase"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of registered user profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of placed customer orders"
    }
  }
}
